% ---------------------------
% Boxes + theorem boxing (ROBUST WAY)
% ---------------------------
\RequirePackage{amsthm}
\RequirePackage[most]{tcolorbox}
\RequirePackage{xparse}

\tcbset{
  basebox/.style={
    enhanced,
    breakable,
    boxrule=0.3pt,
    arc=2pt,
    left=6pt,right=6pt,top=4pt,bottom=4pt,
    colframe=black!20,
    colback=white
  }
}

% --- Define theorem-like envs normally ---
\theoremstyle{definition}
\newtheorem{definition}{Definition}
\newtheorem{remark}{Remark}
\newtheorem{resume1}{Résumé}
\newtheorem{savoir}{Truc}

\theoremstyle{plain}
\newtheorem{theoreme}{Theorem}
\newtheorem{proposition}{Proposition}
\newtheorem{lemme}{Lemme}
\newtheorem{corollaire}{Corollaire}

\theoremstyle{definition}
\newtheorem{exemple}{Exemple}

% --- Now: BOX them automatically (this is the key) ---
\tcolorboxenvironment{definition}{basebox,colback=green!10,colframe=green!25}
\tcolorboxenvironment{theoreme}{basebox,colback=blue!7,colframe=blue!25}
\tcolorboxenvironment{proposition}{basebox,colback=blue!2,colframe=blue!20}
\tcolorboxenvironment{lemme}{basebox,colback=blue!2,colframe=blue!20}
\tcolorboxenvironment{corollaire}{basebox,colback=blue!2,colframe=blue!20}
\tcolorboxenvironment{remark}{basebox,colback=orange!7,colframe=orange!25}
\tcolorboxenvironment{resume1}{basebox,colback=gray!7,colframe=black!20}
\tcolorboxenvironment{savoir}{basebox,colback=orange!7,colframe=orange!20}

% Keep your old env names as wrappers if you want:
\NewDocumentEnvironment{framedremark}{}{%
  \begin{remark}
}{%
  \end{remark}
}
\NewDocumentEnvironment{resume}{}{%
  \begin{resume1}
}{%
  \end{resume1}
}
\NewDocumentEnvironment{truc}{}{%
  \begin{savoir}
}{%
  \end{savoir}
}

% --- Theorem (EN name) ---
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}
\tcolorboxenvironment{theorem}{basebox,colback=blue!7,colframe=blue!25}
% ---------------------------
% parag + code INSIDE
% ---------------------------
\newtcolorbox{parag@box}{basebox}

% IMPORTANT: codebox must NOT be breakable (breakable-in-breakable breaks)
\newtcblisting{codebox}{
  listing engine=listings,
  listing only,
  enhanced,
  breakable=false,
  colback=black!2,
  colframe=black!20,
  boxrule=0.3pt,
  arc=2pt,
  left=6pt,right=6pt,top=4pt,bottom=4pt
}

\NewDocumentEnvironment{parag}{m}{
  \par\medskip
  \noindent\textbf{#1}\par
  \begin{parag@box}
}{
  \end{parag@box}
  \par\medskip
}

% =========================================================
% Pretty headers: Lecture + Chapter
% =========================================================

% Palette (tu peux changer)
\definecolor{maincolour}{HTML}{004A7F} % bleu EPFL-ish
\definecolor{lightframe}{HTML}{D9E2EC}

% ---------------------------------------------------------
% Minimal lecture header
% Usage: \lecture{<no>}{<YYYY-MM-DD>}{<title>}
% ---------------------------------------------------------

\newcommand{\lecture}[3]{%
  \par\bigskip
\needspace{\baselineskip} % garantit place pour chapter juste après
  {\large\bfseries Lecture~#1\enspace—\enspace #2:\enspace #3\par}
  \vspace{0.4em}\hrule height 0.4pt\vspace{0.8em}
}
% ---------------------------------------------------------
% Chapter styling (no "Chapter" word, minimalist)
% ---------------------------------------------------------
\RequirePackage[nobottomtitles]{titlesec}

% If \chapter doesn't exist (article), map it to \section to keep your source compatible
\providecommand{\chapter}{\section}
\providecommand{\chapter*}{\section*}

% Title format: just big text + thin rule
\titleformat{\chapter}
  {\normalfont\Huge\bfseries}
  {}{0pt}{}
  [\vspace{0.6em}\titlerule]

% Spacing: (left, before, after)
\titlespacing*{\chapter}{0pt}{0.0em}{1.0em}

% Unnumbered chapters too (same look)
\titleformat{name=\chapter,numberless}
  {\normalfont\Huge\bfseries}
  {}{0pt}{}
  [\vspace{0.6em}\titlerule]

% ---------------------------------------------------------
% Do NOT force a page break before \chapter (report/book)
% ---------------------------------------------------------
\RequirePackage{etoolbox}
\makeatletter
% Remove \clearpage (report) and also the openright logic (book)
\patchcmd{\chapter}
  {\if@openright\cleardoublepage\else\clearpage\fi}
  {\par\bigskip}
  {}{}
\patchcmd{\chapter}
  {\clearpage}
  {\par\bigskip}
  {}{}
\makeatother
% ---------------------------------------------------------
% TOC formatting for custom \chapter in article
% (prevents "ChapterTitlePage" glued together)
% ---------------------------------------------------------
\RequirePackage{tocloft}

% Give chapter entries proper spacing/number width
\setlength{\cftchapindent}{0pt}
\setlength{\cftchapnumwidth}{2.6em}

% Dots and page separation (optional but usually nice)
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}
\setlength{\cftbeforechapskip}{0.4em}

% Make chapter title in ToC a bit more prominent (optional)
\renewcommand{\cftchappagefont}{\bfseries}
\renewcommand{\cftchapfont}{\bfseries}
