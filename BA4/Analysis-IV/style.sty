% style.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style}[2026/02/22 Notes style (cleaned, report ToC fixed)]

% ---------------------------
% Engine (LuaLaTeX expected)
% ---------------------------
\RequirePackage{iftex}
\ifLuaTeX\else
  \PackageWarning{style}{This style is intended for LuaLaTeX (fontspec).}
\fi

% ---------------------------
% Core / layout
% ---------------------------
\RequirePackage{fontspec}
\RequirePackage[bottom=2.5cm,top=2.5cm]{geometry}
\RequirePackage{microtype}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage[hyphens]{url}
\RequirePackage[breaklinks,hidelinks]{hyperref}
\hypersetup{pdftitle={Notes}}

\setlength{\parindent}{0pt}
\setlength{\parskip}{3pt}

% ---------------------------
% Math
% ---------------------------
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{mathtools}
\RequirePackage{bm}
\RequirePackage{dsfont}
\RequirePackage{esint}
\RequirePackage{centernot}

\newcommand{\R}{\mathbb{R}}
\newcommand{\C}{\mathbb{C}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}

\newcommand{\exval}{\mathbb{E}}
\newcommand{\prob}{\mathbb{P}}

\DeclareMathOperator{\Span}{span}
\DeclareMathOperator{\rank}{rank}
\DeclareMathOperator{\Tr}{Tr}
\DeclareMathOperator*{\argmin}{argmin}
\DeclareMathOperator*{\argmax}{argmax}

% ---------------------------
% Lists
% ---------------------------
\RequirePackage{enumitem}
\setlist{left=15pt, noitemsep, topsep=2pt}
\AtBeginDocument{\def\labelitemi{$\bullet$}}

% ---------------------------
% TikZ / plots (keep if needed)
% ---------------------------
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\RequirePackage{tikz-cd}
\usetikzlibrary{arrows.meta,patterns,decorations.pathmorphing}

% ---------------------------
% Code (listings)
% ---------------------------
\RequirePackage{listings}

\definecolor{bg}{rgb}{0.95,0.95,0.95}
\definecolor{kw}{rgb}{0.00,0.30,0.55}
\definecolor{com}{rgb}{0.30,0.50,0.10}
\definecolor{str}{rgb}{0.80,0.20,0.55}

\lstdefinestyle{notes}{
  backgroundcolor=\color{bg},
  basicstyle=\ttfamily\footnotesize,
  keywordstyle=\bfseries\color{kw},
  commentstyle=\color{com},
  stringstyle=\color{str},
  breaklines=true,
  breakatwhitespace=false,
  showstringspaces=false,
  frame=none,
  tabsize=2
}
\lstset{style=notes}

% ---------------------------
% Boxes + theorem boxing (ROBUST WAY)
% ---------------------------
\RequirePackage{amsthm}
\RequirePackage[most]{tcolorbox}
\RequirePackage{xparse}

\tcbset{
  basebox/.style={
    enhanced,
    breakable,
    boxrule=0.3pt,
    arc=2pt,
    left=6pt,right=6pt,top=4pt,bottom=4pt,
    colframe=black!20,
    colback=white
  }
}

% --- Define theorem-like envs normally ---
\theoremstyle{definition}
\newtheorem{definition}{Definition}
\newtheorem{remark}{Remark}
\newtheorem{resume1}{Résumé}
\newtheorem{savoir}{Truc}

\theoremstyle{plain}
\newtheorem{theoreme}{Theorem}
\newtheorem{prop}{Prop}
\newtheorem{lemma}{Lemma}
\newtheorem{corollary}{Corollary}

\theoremstyle{definition}
\newtheorem{exemple}{Exemple}

% --- Now: BOX them automatically ---
\tcolorboxenvironment{definition}{basebox,colback=green!10,colframe=green!25}
\tcolorboxenvironment{theoreme}{basebox,colback=blue!7,colframe=blue!25}
\tcolorboxenvironment{prop}{basebox,colback=blue!2,colframe=blue!20}
\tcolorboxenvironment{lemma}{basebox,colback=blue!2,colframe=blue!20}
\tcolorboxenvironment{corollary}{basebox,colback=blue!2,colframe=blue!20}
\tcolorboxenvironment{remark}{basebox,colback=orange!7,colframe=orange!25}
\tcolorboxenvironment{resume1}{basebox,colback=gray!7,colframe=black!20}
\tcolorboxenvironment{savoir}{basebox,colback=orange!7,colframe=orange!20}

% Wrappers (kept)
\NewDocumentEnvironment{framedremark}{}{\begin{remark}}{\end{remark}}
\NewDocumentEnvironment{resume}{}{\begin{resume1}}{\end{resume1}}
\NewDocumentEnvironment{truc}{}{\begin{savoir}}{\end{savoir}}

% Optional: also support \begin{theorem} ... \end{theorem}
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}
\tcolorboxenvironment{theorem}{basebox,colback=blue!7,colframe=blue!25}

% ---------------------------
% parag + code INSIDE
% ---------------------------
\newtcolorbox{parag@box}{basebox}

% IMPORTANT: codebox must NOT be breakable (breakable-in-breakable breaks)
\newtcblisting{codebox}{
  listing engine=listings,
  listing only,
  enhanced,
  breakable=false,
  colback=black!2,
  colframe=black!20,
  boxrule=0.3pt,
  arc=2pt,
  left=6pt,right=6pt,top=4pt,bottom=4pt
}

\NewDocumentEnvironment{parag}{m}{
  \par\medskip
  \noindent\textbf{#1}\par
  \begin{parag@box}
}{
  \end{parag@box}
  \par\medskip
}

% ---------------------------
% Lecture header
% ---------------------------
\RequirePackage{needspace}
\newcommand{\lecture}[3]{%
  \par\bigskip
  \needspace{8\baselineskip}%
  {\large\bfseries
    Lecture~#1\enspace—\enspace #2:\nobreak\hspace{0.4em}#3\par
  }%
  \vspace{0.4em}\hrule height 0.4pt\vspace{0.8em}%
}

% ---------------------------
% Chapter styling 
% ---------------------------
\RequirePackage[nobottomtitles]{titlesec}

\titleformat{\chapter}[block]
  {\normalfont}
  {}
  {0pt}
  {%
    {\huge\bfseries Chapter~\thechapter}\\[0.8em]%
    \fontsize{28}{32}\selectfont\bfseries%
  }
  [\vspace{0.6em}\titlerule]

\titlespacing*{\chapter}{0pt}{3.0em}{1.0em}

\titleformat{name=\chapter,numberless}[block]
  {\normalfont\Huge\bfseries}
  {}{0pt}{}
  [\vspace{0.6em}\titlerule]

\RequirePackage{etoolbox}

% 1) A simple flag
\newif\ifafterlecture
\afterlecturefalse

% 2) When \lecture is called, set the flag + reserve enough space
\pretocmd{\lecture}{\global\afterlecturetrue\Needspace{18\baselineskip}}{}{}

% 3) Wrap \chapter so that ONLY the chapter right after a lecture
%    does NOT force a page break.
\makeatletter
\let\style@origchapter\chapter
\renewcommand{\chapter}{\@ifstar\style@chapter@star\style@chapter@nostar}

\newcommand{\style@chapter@nostar}[1]{%
  \ifafterlecture
    \begingroup
      \let\clearpage\relax
      \let\cleardoublepage\relax
      \style@origchapter{#1}%
    \endgroup
    \global\afterlecturefalse
  \else
    \style@origchapter{#1}%
  \fi
}

\newcommand{\style@chapter@star}[1]{%
  \ifafterlecture
    \begingroup
      \let\clearpage\relax
      \let\cleardoublepage\relax
      \style@origchapter*{#1}%
    \endgroup
    \global\afterlecturefalse
  \else
    \style@origchapter*{#1}%
  \fi
}
\makeatother
